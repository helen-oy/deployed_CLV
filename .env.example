# Configuration for CLV Prediction API

# Environment
ENVIRONMENT=development
LOG_LEVEL=INFO

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=false

# Data Configuration
DATA_SOURCE=csv
CSV_PATH=data/customer_segmentation.csv
# For SQL uncomment and set these:
# SQL_CONNECTION=postgresql://user:password@localhost:5432/customer_db
# SQL_QUERY=SELECT * FROM customers

# Model Configuration
CONFIG_PATH=config.yaml
OUTPUT_DIR=models/
PLOTS_DIR=models/plots/

# Azure Configuration (if deploying to Azure)
AZURE_STORAGE_ACCOUNT=
AZURE_STORAGE_KEY=
AZURE_CONTAINER_NAME=clv-models

# Database (if using Azure SQL)
AZURE_SQL_SERVER=
AZURE_SQL_DATABASE=
AZURE_SQL_USER=
AZURE_SQL_PASSWORD=
